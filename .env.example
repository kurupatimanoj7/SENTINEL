SENTINEL_ADMIN_TOKEN=replace-with-a-long-random-admin-token
SENTINEL_HMAC_SECRET=replace-with-a-long-random-hmac-secret
SENTINEL_HOST=127.0.0.1
SENTINEL_PORT=5000

# Optional: Override defaults
SENTINEL_NODE_ID=storage_primary
SENTINEL_ENTRY_NODE=entry_gateway
SENTINEL_STORAGE_NODE=storage_node
SENTINEL_MAX_UPLOAD_BYTES=10485760
SENTINEL_RATE_LIMIT=10 per hour

